# vim:set ft=l4mods:

modaddr 0x01100000

default-kernel fiasco -serial_esc
default-bootstrap bootstrap vesa=0x115

entry mosaicos-hello
roottask moe rom/mosaicos-hello.cfg
module l4re
module ned
module mosaicos-hello.cfg
module mosaic-hello

entry mosaicos-init
roottask moe rom/mosaicos-init.cfg
module l4re
module ned
module mosaicos-init.cfg
module mosaic-init.manifest
module mosaic-init
module mosaic-log
module mosaic-hello
module mosaic-status
module mosaic-crash

entry mosaicos-recovery
roottask moe rom/mosaicos-recovery.cfg
module l4re
module ned
module mosaicos-recovery.cfg
module mosaic-recovery.manifest
module mosaic-init
module mosaic-log
module mosaic-status
module mosaic-crash
module mosaic-safe-gui

entry mosaicos-graphical
roottask moe rom/mosaicos-graphical.cfg
module l4re
module ned
module mosaicos-graphical.cfg
module x86-fb.io
module io
module io/x86-legacy.devs
module mosaic-graphical.manifest
module mosaic-init
module mosaic-log
module mosaic-display
module mosaic-input
module mosaic-compositor
module mosaic-safe-gui
module mosaic-graphical-hello
module mosaic-status

entry mosaicos-graphical-recovery
roottask moe rom/mosaicos-graphical-recovery.cfg
module l4re
module ned
module mosaicos-graphical-recovery.cfg
module x86-fb.io
module io
module io/x86-legacy.devs
module mosaic-graphical-recovery.manifest
module mosaic-init
module mosaic-log
module mosaic-display
module mosaic-input
module mosaic-compositor-crash
module mosaic-safe-gui
module mosaic-status

entry mosaicos-ipc-ping
roottask moe rom/mosaicos-ipc-ping.cfg
module l4re
module ned
module mosaicos-ipc-ping.cfg
