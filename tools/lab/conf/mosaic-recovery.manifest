# Milestone 4 recovery manifest.
services:
  logger:
    binary: rom/mosaic-log
    restart: never

  crashy:
    binary: rom/mosaic-crash
    restart: on-failure
    requires:
      - logger
    recovery:
      max_restarts: 2
      fallback: safe-gui

  safe-gui:
    binary: rom/mosaic-safe-gui
    restart: never
    start: manual
    requires:
      - logger

  status:
    binary: rom/mosaic-status
    restart: never
    requires:
      - logger
